{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["DOM", "ES2020"],
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "web/static/ts",
    "outDir": "web/static/js",
    "removeComments": false
  },
  "include": ["web/static/ts/**/*.ts"]
}
